# --- Portal environment (copy to .env.local for local dev) ---

# Shared platform Postgres (CONTRACT §6). Better Auth uses the `auth` schema;
# the portal reads/writes app.users and app.api_keys in the `app` schema.
DATABASE_URL=postgres://synergy:synergy@localhost:5432/synergy?sslmode=disable

# Better Auth: signing secret (>=32 chars) and the portal's own base URL.
# Generate a real secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Public base URL of the SynergyPlus API gateway, shown in Getting Started.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8090

# Dev login: surface the magic link in the UI + console (no mailbox needed).
# Defaults on when NODE_ENV != production. Set to 0 to force-disable.
PORTAL_DEV_LOGIN=1
