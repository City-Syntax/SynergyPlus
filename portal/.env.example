# --- Portal environment (copy to .env.local for local dev) ---

# Shared platform Postgres (CONTRACT §6). Better Auth uses the `auth` schema;
# the portal reads/writes app.users and app.api_keys in the `app` schema.
DATABASE_URL=postgres://synergy:synergy@localhost:5432/synergy?sslmode=disable

# Better Auth: signing secret (>=32 chars) and the portal's own base URL.
# Generate a real secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Public base URL of the SynergyPlus API gateway, shown in Getting Started.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8090

# Dev login: surface the magic link in the UI + console (no mailbox needed).
# Defaults on when NODE_ENV != production. Set to 0 to force-disable.
PORTAL_DEV_LOGIN=1

# Email domains allowed to sign in (comma-separated). Fail-closed: if unset, no
# one can log in. Set this to your organisation's domains.
ALLOWED_EMAIL_DOMAINS=

# --- Outgoing magic-link email (production) ---
# Only needed when PORTAL_DEV_LOGIN=0 (i.e. NODE_ENV=production): the portal then
# delivers sign-in links over generic SMTP instead of surfacing them in the UI.
# Provider-agnostic — point at SES SMTP, Resend, Postmark, Mailgun, or your own
# relay. Verify the sender domain (SPF + DKIM + DMARC) or links land in spam.
# MAIL_FROM=SynergyPlus <noreply@yourdomain.com>
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=     # 1 = implicit TLS (port 465), 0 = STARTTLS. Auto from port if unset.
